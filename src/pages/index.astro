---
import { Image } from "astro:assets";
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlogCard from "@/components/BlogCard.astro";
import NotebookCard from "@/components/NotebookCard.astro";
import { getCollection } from "astro:content";
import { SITE, SOCIAL_LINKS } from "@/lib/constants";
import lucaPhoto from "@/assets/luca-baroncini.jpg";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const github = SOCIAL_LINKS.find((l) => l.icon === "github")!;
const linkedin = SOCIAL_LINKS.find((l) => l.icon === "linkedin")!;
---

<BaseLayout title={SITE.title} description={SITE.description}>
  <NotebookCard label="profile.md" class="fade-in-observed mt-2">
    <div class="flex flex-col items-start gap-6 sm:flex-row sm:gap-8">
      <Image
        src={lucaPhoto}
        alt="Luca Baroncini"
        width={120}
        height={120}
        data-full-src={lucaPhoto.src}
        class="lightbox-target shrink-0 cursor-zoom-in border border-text object-cover object-top"
        style="filter: grayscale(0.4) contrast(1.1); aspect-ratio: 1 / 1;"
      />
      <div class="font-mono">
        <h1 class="text-[22px] font-semibold leading-tight">
          <span class="text-accent"># </span>Luca Baroncini
        </h1>
        <p class="mt-3 text-[13px] leading-relaxed text-text-secondary">
          Tecnologia, sviluppo web, politica e arrampicata.<br />
          Scrivo appunti, storie e opinioni. Niente tracking, niente cookie.
        </p>
        <div class="mt-4 flex flex-wrap gap-x-4 gap-y-1 text-[12px]">
          <a href="/about" class="text-accent transition-colors hover:text-accent-hover">
            → chi sono
          </a>
          <a
            href={github.href}
            target="_blank"
            rel="noopener noreferrer"
            class="text-accent transition-colors hover:text-accent-hover"
          >
            → github
          </a>
          <a
            href={linkedin.href}
            target="_blank"
            rel="noopener noreferrer"
            class="text-accent transition-colors hover:text-accent-hover"
          >
            → linkedin
          </a>
          <a href="/rss.xml" class="text-accent transition-colors hover:text-accent-hover">
            → rss
          </a>
        </div>
      </div>
    </div>
  </NotebookCard>

  <section class="mt-16">
    <div
      class="flex items-center justify-between border-b border-dashed border-notebook-rule pb-2 font-mono"
      style="letter-spacing: 0.15em;"
    >
      <h2 class="text-[13px] uppercase">
        <span class="text-accent">## </span>posts.latest
      </h2>
      <a
        href="/blog"
        class="text-[11px] uppercase text-text-secondary transition-colors hover:text-accent"
      >
        ls -la →
      </a>
    </div>

    <div class="stagger-children mt-2">
      {
        posts.map((post) => (
          <BlogCard
            title={post.data.title}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            slug={post.id}
          />
        ))
      }
    </div>

    {posts.length === 0 && (
      <p class="mt-6 font-mono text-sm text-text-secondary">
        // nessun articolo ancora
      </p>
    )}
  </section>
</BaseLayout>
