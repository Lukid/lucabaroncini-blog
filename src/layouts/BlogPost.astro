---
import BaseLayout from "./BaseLayout.astro";
import CopyButton from "@/components/CopyButton.astro";
import { SITE } from "@/lib/constants";
import { formatISOShort } from "@/lib/format";
import type { Tag } from "@/lib/constants";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: ImageMetadata;
  tags: Tag[];
  prevPost?: { slug: string; title: string };
  nextPost?: { slug: string; title: string };
  readingTime?: number;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  tags,
  prevPost,
  nextPost,
  readingTime,
} = Astro.props;

const pubShort = formatISOShort(pubDate);
const updatedShort = updatedDate ? formatISOShort(updatedDate) : undefined;
const tagsSerialized = JSON.stringify(tags);
---

<BaseLayout
  title={title}
  description={description}
  type="article"
  pubDate={pubDate}
  updatedDate={updatedDate}
>
  <article>
    <header class="fade-in-observed mb-10">
      {/* Frontmatter block */}
      <div class="frontmatter-block relative border border-text bg-surface px-6 py-5 font-mono text-[13px] leading-[1.7]">
        <div class="frontmatter-rule">---</div>
        <div>
          <span class="text-accent">title:</span>
          <span> "{title}"</span>
        </div>
        <div>
          <span class="text-accent">pubDate:</span>
          <span> {pubShort}</span>
        </div>
        {
          updatedShort && (
            <div>
              <span class="text-accent">updatedDate:</span>
              <span> {updatedShort}</span>
            </div>
          )
        }
        {
          tags.length > 0 && (
            <div>
              <span class="text-accent">tags:</span>
              <span> {tagsSerialized}</span>
            </div>
          )
        }
        {
          readingTime && (
            <div>
              <span class="text-accent">readingTime:</span>
              <span> {readingTime}</span>
            </div>
          )
        }
        <div class="frontmatter-rule">---</div>
      </div>

      {/* Title — Fraunces stays */}
      <h1
        class="mt-10 font-display text-4xl font-black tracking-tight sm:text-5xl lg:text-[56px]"
        style="font-variation-settings: 'opsz' 48, 'WONK' 1; line-height: 1.05;"
      >
        {title}
      </h1>

      {/* Description / deck */}
      <p
        class="mt-6 border-l-[3px] border-accent pl-[14px] font-mono text-[14px] text-text-secondary"
      >
        {description}
      </p>

      {
        tags.length > 0 && (
          <div class="mt-5 flex flex-wrap gap-2 font-mono text-[11px] text-text-secondary">
            {tags.map((tag) => (
              <a
                href={`/tags/${tag}`}
                class="transition-colors hover:text-accent"
              >
                <span class="text-accent">#</span>
                {tag}
              </a>
            ))}
          </div>
        )
      }
    </header>

    {
      heroImage && (
        <img
          src={heroImage.src}
          width={heroImage.width}
          height={heroImage.height}
          alt={title}
          class="mb-12 w-full border border-border"
          loading="eager"
          decoding="async"
        />
      )
    }

    <div class="prose">
      <slot />
    </div>

    <CopyButton />

    {/* Post navigation */}
    {
      (prevPost || nextPost) && (
        <nav class="mt-12 flex flex-col gap-4 border-t border-dashed border-notebook-rule pt-8 font-mono sm:flex-row sm:justify-between">
          {prevPost ? (
            <a href={`/blog/${prevPost.slug}`} class="group text-[13px]">
              <span class="text-[11px] uppercase text-text-secondary">
                ← prev
              </span>
              <span
                class="mt-1 block transition-colors group-hover:text-accent"
                style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;"
              >
                {prevPost.title}
              </span>
            </a>
          ) : (
            <div />
          )}
          {nextPost && (
            <a
              href={`/blog/${nextPost.slug}`}
              class="group text-right text-[13px]"
            >
              <span class="text-[11px] uppercase text-text-secondary">
                next →
              </span>
              <span
                class="mt-1 block transition-colors group-hover:text-accent"
                style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;"
              >
                {nextPost.title}
              </span>
            </a>
          )}
        </nav>
      )
    }
  </article>
</BaseLayout>

<style>
  .frontmatter-block {
    /* reserve space for fake --- rules */
  }
  .frontmatter-rule {
    color: var(--color-text-secondary);
    user-select: none;
  }
</style>
