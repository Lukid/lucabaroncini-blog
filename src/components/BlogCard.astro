---
import type { Tag } from "@/lib/constants";
import { formatISOShort } from "@/lib/format";

interface Props {
  title: string;
  pubDate: Date;
  tags: Tag[];
  slug: string;
}

const { title, pubDate, tags, slug } = Astro.props;

const isoShort = formatISOShort(pubDate);
---

<a
  href={`/blog/${slug}`}
  class="blog-row group block border-b border-dashed border-notebook-rule font-mono text-[14px] transition-colors"
>
  <div class="blog-row-grid items-baseline gap-5 py-[14px]">
    <time
      datetime={pubDate.toISOString()}
      class="text-[11px] text-text-secondary"
    >
      {isoShort}
    </time>
    <span class="truncate">
      <span class="text-accent">→ </span>{title}
    </span>
    {
      tags.length > 0 && (
        <span class="hidden shrink-0 text-[10px] text-text-secondary sm:inline-flex sm:gap-2">
          {tags.slice(0, 3).map((tag) => (
            <span>
              <span class="text-accent">#</span>
              {tag}
            </span>
          ))}
        </span>
      )
    }
  </div>
</a>

<style>
  .blog-row-grid {
    display: grid;
    grid-template-columns: 90px 1fr auto;
  }
  @media (max-width: 640px) {
    .blog-row-grid {
      grid-template-columns: 80px 1fr;
    }
  }
  .blog-row {
    padding-inline: 0;
    transition: background-color 0.15s, padding 0.15s;
  }
  .blog-row:hover {
    background-color: color-mix(in oklch, var(--color-accent) 8%, transparent);
    padding-inline: 8px;
  }
  @media (hover: none) {
    .blog-row-grid {
      padding-top: 18px;
      padding-bottom: 18px;
    }
  }
</style>
