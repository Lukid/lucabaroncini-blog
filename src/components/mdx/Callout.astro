---
interface Props {
  type?: "info" | "warning" | "tip" | "danger" | "note";
}

const { type = "info" } = Astro.props;

const labels = {
  info: "NOTE",
  note: "NOTE",
  tip: "TIP",
  warning: "WARNING",
  danger: "DANGER",
} as const;

const label = labels[type];
---

<aside
  class="relative my-8 border border-text bg-surface px-[22px] py-[18px] font-mono text-[14px] leading-[1.7]"
  role="note"
>
  <span
    class="absolute -top-[9px] left-5 bg-bg px-2 font-mono text-[10px] text-accent"
    style="letter-spacing: 0.2em;"
    aria-hidden="true"
  >
    [ {label} ]
  </span>
  <div class="[&>p]:my-0 [&>p+p]:mt-3">
    <slot />
  </div>
</aside>
