---
import ThemeToggle from "./ThemeToggle.astro";
import { NAV_ITEMS, SITE } from "@/lib/constants";

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === "/") return currentPath === "/";
  return currentPath === href || currentPath.startsWith(href + "/");
}
---

<header class="border-b border-text bg-bg">
  <nav class="mx-auto flex max-w-4xl items-center justify-between px-6 py-4 font-mono sm:px-8">
    <a href="/" class="text-sm font-medium">
      <span class="text-accent">~$ </span>luca.baroncini
    </a>

    {/* Desktop nav */}
    <div class="hidden items-center gap-2 sm:flex">
      {
        NAV_ITEMS.map((item) => {
          const active = isActive(item.href);
          return (
            <a
              href={item.href}
              class:list={[
                "border px-2.5 py-1 text-xs transition-colors",
                active
                  ? "border-text bg-text text-bg"
                  : "border-transparent hover:border-text",
              ]}
            >
              {item.href}
            </a>
          );
        })
      }
      <ThemeToggle />
    </div>

    {/* Mobile toggle */}
    <div class="flex items-center gap-2 sm:hidden">
      <ThemeToggle />
      <button
        id="mobile-menu-toggle"
        type="button"
        aria-label="Apri menu"
        aria-expanded="false"
        class="border border-text px-2 py-1 text-xs transition-colors hover:bg-text hover:text-bg"
      >
        <span aria-hidden="true">[ menu ]</span>
      </button>
    </div>
  </nav>

  {/* Mobile menu */}
  <div id="mobile-menu" class="hidden border-t border-text sm:hidden">
    <div class="mx-auto max-w-4xl px-6 py-3 font-mono sm:px-8">
      {
        NAV_ITEMS.map((item) => {
          const active = isActive(item.href);
          return (
            <a
              href={item.href}
              class:list={[
                "block border px-3 py-2 text-xs transition-colors",
                "mb-1 last:mb-0",
                active
                  ? "border-text bg-text text-bg"
                  : "border-transparent hover:border-text",
              ]}
            >
              <span class="text-accent">→ </span>
              {item.href}
            </a>
          );
        })
      }
    </div>
  </div>
</header>

<script>
  function setupMobileMenu() {
    const toggle = document.getElementById("mobile-menu-toggle");
    const menu = document.getElementById("mobile-menu");

    function closeMenu() {
      toggle?.setAttribute("aria-expanded", "false");
      menu?.classList.add("hidden");
    }

    toggle?.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!expanded));
      menu?.classList.toggle("hidden");
    });

    menu?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && toggle?.getAttribute("aria-expanded") === "true") {
        closeMenu();
        toggle.focus();
      }
    });
  }
  setupMobileMenu();
  document.addEventListener("astro:after-swap", setupMobileMenu);
</script>
